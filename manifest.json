{
  "manifest_version": 3,
  "name": "InterceptX",
  "version": "1.0.0",
  "description": "Easily add, modify, and delete HTTP request and response headers on the fly.",
  "permissions": [
    "declarativeNetRequest",
    "storage",
    "tabs",
    "downloads"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "ui/popup.html",
    "default_title": "InterceptX",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_page": "ui/popup.html"
}
